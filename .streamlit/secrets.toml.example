# Copy these keys into Streamlit Community Cloud's Secrets editor.
# Do not commit a real .streamlit/secrets.toml file.

# Optional demo gate. Leave blank to keep the app open.
CONSENSUS_SCOPE_DEMO_PASSWORD = ""
CONSENSUS_SCOPE_AUTH_ENABLED = false

# External database for main demo teacher-queue decisions and expert annotations.
# Run consensusscope_supabase_schema.sql before enabling these.
SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "your-service-role-key"

# Optional. Keep false unless you intentionally want to store queue item text
# and AI suggestions in the main demo database.
CONSENSUS_SCOPE_STORE_DECISION_PAYLOAD = false

DEEPSEEK_API_KEY = ""
DEEPSEEK_BASE_URL = "https://api.deepseek.com"
DEEPSEEK_MODEL = "deepseek-chat"

QWEN_API_KEY = ""
QWEN_BASE_URL = "https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL = "qwen-plus"

GLM_API_KEY = ""
GLM_BASE_URL = "https://open.bigmodel.cn/api/paas/v4"
GLM_MODEL = "glm-4-flash"

KIMI_API_KEY = ""
KIMI_BASE_URL = "https://api.moonshot.cn/v1"
KIMI_MODEL = "moonshot-v1-8k"

OPENAI_API_KEY = ""
OPENAI_BASE_URL = "https://api.openai.com/v1"
OPENAI_MODEL = "gpt-4o-mini"

JUDGE_API_KEY = ""
JUDGE_BASE_URL = "https://api.deepseek.com"
JUDGE_MODEL = "deepseek-chat"
